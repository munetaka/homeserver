{
  "uid": "home-power",
  "title": "電力モニタリング",
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "1m",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "太陽光発電",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "text",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(power_generation_w)",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "総消費電力",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              },
              {
                "color": "yellow",
                "value": 3000
              },
              {
                "color": "red",
                "value": 6000
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(power_generation_w) + sum(power_grid_w)",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "系統電力 (正=買電 / 負=売電)",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(power_grid_w)",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "自家消費率 (発電中のみ)",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 0,
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "100 * (sum(power_generation_w) - clamp_min(-sum(power_grid_w), 0)) / sum(power_generation_w)",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "電力収支: 自家消費+買電(上) / 売電(下)",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 55,
            "stacking": {
              "mode": "normal"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "自家消費"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "買電"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "yellow"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "売電"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "blue"
                }
              },
              {
                "id": "custom.transform",
                "value": "negative-Y"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "発電"
            },
            "properties": [
              {
                "id": "custom.stacking",
                "value": {
                  "mode": "none"
                }
              },
              {
                "id": "custom.drawStyle",
                "value": "line"
              },
              {
                "id": "custom.fillOpacity",
                "value": 0
              },
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "dark-green"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "総消費"
            },
            "properties": [
              {
                "id": "custom.stacking",
                "value": {
                  "mode": "none"
                }
              },
              {
                "id": "custom.drawStyle",
                "value": "line"
              },
              {
                "id": "custom.fillOpacity",
                "value": 0
              },
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "orange"
                }
              }
            ]
          },
          {
            "__systemRef": "hideSeriesFrom",
            "matcher": {
              "id": "byNames",
              "options": {
                "mode": "exclude",
                "names": [
                  "自家消費",
                  "買電",
                  "売電"
                ],
                "prefix": "All except:",
                "readOnly": true
              }
            },
            "properties": [
              {
                "id": "custom.hideFrom",
                "value": {
                  "viz": true,
                  "legend": false,
                  "tooltip": false
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "自家消費",
          "expr": "(sum(power_generation_w) - clamp_min(-sum(power_grid_w), 0)) or ((sum(energy_30min_kwh{kind=\"generation\"}) - sum(energy_30min_kwh{kind=\"sell\"})) * 2000)"
        },
        {
          "refId": "B",
          "legendFormat": "買電",
          "expr": "clamp_min(sum(power_grid_w), 0) or (sum(energy_30min_kwh{kind=\"buy\"}) * 2000)"
        },
        {
          "refId": "C",
          "legendFormat": "売電",
          "expr": "clamp_min(-sum(power_grid_w), 0) or (sum(energy_30min_kwh{kind=\"sell\"}) * 2000)"
        },
        {
          "refId": "D",
          "legendFormat": "発電",
          "expr": "sum(power_generation_w) or (sum(energy_30min_kwh{kind=\"generation\"}) * 2000)"
        },
        {
          "refId": "E",
          "legendFormat": "総消費",
          "expr": "(sum(power_generation_w) + sum(power_grid_w)) or (sum(energy_30min_kwh{kind=\"consumption\"}) * 2000)"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "回路別消費電力 (スタック、過去は30分平均)",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 0,
            "fillOpacity": 60,
            "stacking": {
              "mode": "normal"
            }
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "(sum by (circuit, name) (power_circuit_watts) or (sum by (circuit, name) (energy_30min_circuit_kwh) * 2000)) > 0",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "エアコン消費電力",
      "gridPos": {
        "h": 8,
