# 書き込み先 (VictoriaMetrics の line protocol 互換エンドポイント)
INFLUX_URL=http://localhost:8428

# location タグの接頭辞
LOCATION_PREFIX=home-

# HTTP タイムアウト (秒)
REQUEST_TIMEOUT_S=10

# 絶対湿度の増強係数モデル: none / buck / its90
EF_MODEL=its90

# SwitchBot BLE センサー (MAC[@type][=alias] のカンマ区切り。type: meter / co2 / hub2)
SWITCHBOT_BLE_DEVICES=B0:E9:FE:54:48:8F@co2=bedroom,F2:B2:02:06:4A:8B@meter=toilet
SWITCHBOT_BLE_SCAN_TIMEOUT=20

# ECHONET Lite 電力機器 (IP@type[=alias]。type: solar / powerboard / aircon / ecocute)
ECHONET_DEVICES=192.168.11.10@solar=太陽光,192.168.11.10@powerboard=分電盤
ECHONET_TIMEOUT_S=3

# 分電盤の回路名と未使用回路 (任意)
ECHONET_CIRCUIT_NAMES=1=リビング,2=玄関ホール,11=冷蔵庫
ECHONET_CIRCUIT_EXCLUDE=26,28
