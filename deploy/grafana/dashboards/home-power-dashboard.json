      "targets": [
        {
          "refId": "A",
          "legendFormat": "自家消費",
          "interval": "1d",
          "expr": "(sum(energy_day_kwh{kind=\"generation\"}) - sum(energy_day_kwh{kind=\"sell\"})) or (sum(increase(power_generation_total_kwh[1d] offset -1d)) - sum(increase(power_sell_total_kwh[1d] offset -1d)))"
