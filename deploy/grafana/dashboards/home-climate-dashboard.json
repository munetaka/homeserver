{
  "uid": "home-climate",
  "title": "自宅環境モニタリング",
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "1m",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "温度 (°C)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "spanNulls": 300000
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "climate_temperature",
          "legendFormat": "{{location}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "相対湿度 (%)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "humidity",
          "min": 0,
          "max": 100,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "spanNulls": 300000
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "climate_humidity",
          "legendFormat": "{{location}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "CO2 (ppm)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ppm",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "spanNulls": 300000
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1000
              },
              {
                "color": "red",
                "value": 1500
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "climate_co2",
          "legendFormat": "{{location}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "絶対湿度 (g/m³)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "spanNulls": 300000
          },
          "decimals": 2
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "climate_abs_humidity",
          "legendFormat": "{{location}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "bargauge",
      "title": "電池残量 (%)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "options": {
        "displayMode": "lcd",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 20
              },
              {
                "color": "green",
                "value": 50
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "climate_battery",
          "legendFormat": "{{location}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "露点温度 (°C) — 表面温度がこれを下回ると結露",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "decimals": 1,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "spanNulls": 300000
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "with (g = ln(climate_humidity/100) + 17.62*climate_temperature/(243.12+climate_temperature)) 243.12*g/(17.62-g)",
          "legendFormat": "{{location}}",
          "refId": "A"
        }
      ]
    }
  ]
}